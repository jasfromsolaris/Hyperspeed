# Operator-only secrets for Wrangler (cf:bootstrap, cf:deploy, cf:secrets).
# Copy to .env in this directory (gitignored). Do not commit real values.
#
# Optional: set HYPERSPEED_OPERATOR_ENV to another file path instead.

CLOUDFLARE_API_TOKEN=
# Optional separate token if your DNS token cannot manage Workers/KV:
# CLOUDFLARE_WORKERS_API_TOKEN=

# URL of the private control plane (no trailing slash), e.g. https://your-cp.onrender.com
WORKER_CONTROL_PLANE_URL=

# Must match CONTROL_PLANE_BEARER_TOKEN on the control plane service.
CONTROL_PLANE_BEARER_TOKEN=

# Server-to-server token accepted by POST /v1/admin/bootstrap-token.
# Set the same value on control-plane as WORKER_ADMIN_TOKEN.
WORKER_ADMIN_TOKEN=
