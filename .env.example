# Hyperspeed — copy to `.env` in the repo root (Docker Compose loads it automatically).
# First deploy: `docker compose up --build` works without this file (defaults in docker-compose.yml).
# Production checklist: README_SELF_HOST.md

# --- Compose / Caddy (host) ---
# CADDY_HTTP_PORT=18080
# CADDY_EMAIL=postmaster@example.com

# --- API (values below are passed into the api service by Compose) ---
JWT_SECRET=
DEBUG=1
# Base64, exactly 32 bytes. Required in production (Terminal SSH storage).
# openssl rand -base64 32
HS_SSH_ENCRYPTION_KEY=

# Browser origin the API accepts. Default stack: http://localhost:18080 (matches default Caddy port).
CORS_ORIGIN=http://localhost:18080
# When users open the app on a public HTTPS URL, set to that origin (scheme + host, port if non-default).
# PUBLIC_API_BASE_URL=

# Optional hints for onboarding (public URL users type in the browser).
# PUBLIC_APP_URL=

# IDE Git clones (per-space working trees). Compose sets a default inside the container.
# HS_GIT_WORKDIR_BASE=/var/lib/hyperspeed/git

# --- Gifted *.hyperspeedapp.com DNS (optional) ---
# When set, the API can call Hyperspeed’s provisioning gateway. Prefer secrets files on the host
# (see docker-compose.provisioning-secrets.yml) instead of pasting secrets here.
# PROVISIONING_BASE_URL=https://provision-gw.hyperspeedapp.com
# PROVISIONING_INSTALL_ID=
# PROVISIONING_INSTALL_SECRET=
# PROVISIONING_INSTALL_ID_FILE=
# PROVISIONING_INSTALL_SECRET_FILE=
# One-time: exchange for install credentials on first boot; persisted under PROVISIONING_STATE_PATH.
# PROVISIONING_BOOTSTRAP_TOKEN=
# PROVISIONING_STATE_PATH=/var/lib/hyperspeed/provisioning/state.json
# Override gateway URL for bootstrap only (defaults to production Worker).
# PROVISIONING_BOOTSTRAP_GATEWAY_URL=

# --- Web image build (Compose build args for apps/web) ---
# VITE_YJS_COLLAB=true

# --- Optional: API image build args ---
# HYPERSPEED_VERSION=1.0.0
# HYPERSPEED_GIT_SHA=

# --- Optional: in-app update banner (user must opt in on Dashboard) ---
# UPSTREAM_GITHUB_REPO=owner/repo
# UPDATE_MANIFEST_URL=

# --- Optional: S3-compatible storage (Compose defaults to bundled MinIO) ---
# FILES_S3_ENDPOINT=
# FILES_S3_REGION=
# FILES_S3_BUCKET=
# FILES_S3_ACCESS_KEY=
# FILES_S3_SECRET_KEY=
# FILES_S3_FORCE_PATH_STYLE=true

# --- Local dev without Docker (run API from apps/api with Postgres/Redis up) ---
# DATABASE_URL=postgres://hyperspeed:hyperspeed@localhost:5432/hyperspeed?sslmode=disable
# REDIS_URL=redis://localhost:6379/0
# HTTP_ADDR=:8080

# --- Local dev: Vite (apps/web) with native API ---
# VITE_API_URL=http://localhost:8080
# CORS_ORIGIN=http://localhost:5173

# --- Optional: OpenRouter AI tuning (server-side; see apps/api env names) ---
# OPENROUTER_CHAT_TOOLS_ENABLED=true
# OPENROUTER_WEB_SEARCH_TOOL=true
# OPENROUTER_CHAT_MAX_TOOL_ITERATIONS=12
# OPENROUTER_CHAT_REASONING_JSON=
# OPENROUTER_CHAT_MAX_TOKENS=16000
# OPENROUTER_PLUGINS_JSON=
