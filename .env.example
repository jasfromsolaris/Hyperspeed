# Copy to .env and fill in values for self-hosting.
# Docker Compose will automatically read .env in this directory.

# Required (production)
# Use a strong random string (>= 32 chars).
JWT_SECRET=

# Required when using Terminal SSH connection storage (recommended always).
# Must be base64 for exactly 32 bytes.
# Generate with (Linux/macOS):  openssl rand -base64 32
HS_SSH_ENCRYPTION_KEY=

# Optional: directory for IDE Git clones (per-space working trees). Unset = Git panel shows unavailable.
# HS_GIT_WORKDIR_BASE=/var/lib/hyperspeed/git

# When running behind the built-in web container (nginx proxy), this can be the same origin.
# For dev with Vite: http://localhost:5173 (or whatever Vite uses).
CORS_ORIGIN=http://localhost:3000

# Optional: public URL users will use in production (onboarding hints). e.g. https://hyperspeed.example.com
# PUBLIC_APP_URL=

# Optional: override the published HTTP bind address in the API container.
# HTTP_ADDR=:8080

# Optional: object storage overrides (MinIO defaults are provided in docker-compose.yml).
# FILES_S3_ENDPOINT=
# FILES_S3_REGION=
# FILES_S3_BUCKET=
# FILES_S3_ACCESS_KEY=
# FILES_S3_SECRET_KEY=
# FILES_S3_FORCE_PATH_STYLE=true

# Copy to .env and adjust. Used by docker-compose and local dev.

# --- API ---
DATABASE_URL=postgres://hyperspeed:hyperspeed@localhost:5432/hyperspeed?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-at-least-32-random-bytes-in-production
HTTP_ADDR=:8080

# Verbose text logs + extra CORS origins for local dev (never set in production)
# DEBUG=true

# Optional: gifted *.hyperspeedapp.com via Hyperspeed DNS control plane (never put Cloudflare tokens in the public API repo for production—use secrets).
# With docker-compose.provisioning.yml, put these in the repo-root .env and/or apps/control-plane/.env (both are loaded; same keys in either file):
# CONTROL_PLANE_BEARER_TOKEN=  # long random string; same for control plane and API
# CLOUDFLARE_API_TOKEN=        # Cloudflare → API Tokens → Zone DNS Edit (or equivalent)
# CLOUDFLARE_ZONE_ID=          # Zone overview → Zone ID for GIFTED_DNS_BASE_DOMAIN
# GIFTED_DNS_BASE_DOMAIN=hyperspeedapp.com
# CLOUDFLARE_PROXIED=false     # usually false so customer terminates TLS
# Then run:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.provisioning.yml up -d --build
# HTTPS for the control plane only (self-signed): https://localhost:8443/health
# Plain HTTP (same service): http://localhost:8787/health

# Optional: API build metadata (docker compose build args for apps/api; see README_SELF_HOST.md)
# HYPERSPEED_VERSION=1.0.0
# HYPERSPEED_GIT_SHA=

# Optional: in-app update notices (GitHub or static manifest; user must opt in on Dashboard)
# UPSTREAM_GITHUB_REPO=owner/hyperspeed
# UPDATE_MANIFEST_URL=https://example.com/hyperspeed-release.json

# CORS: browser origin for the SPA (Vite dev) or Docker UI on port 3000
# CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=http://localhost:3000
# Public HTTPS team URL (same as the address users type in the browser):
# CORS_ORIGIN=https://www.<team>.hyperspeedapp.com
# PUBLIC_API_BASE_URL=https://www.<team>.hyperspeedapp.com

# Caddy (docker-compose caddy service): automatic HTTPS for CADDY_PUBLIC_HOST via Let's Encrypt.
# Leave CADDY_PUBLIC_HOST=localhost for HTTP-only local Docker. Set to your public hostname for TLS.
# CADDY_PUBLIC_HOST=www.<team>.hyperspeedapp.com
# CADDY_EMAIL=you@example.com

# --- Web (Vite) ---
VITE_API_URL=http://localhost:8080

# Yjs + y-monaco CRDT for live collaborative editing on Space Files (same tab/session).
# Requires Redis up and the file collab WebSocket (REDIS_URL on the API). Set false to disable.
VITE_YJS_COLLAB=true

# --- Docker Compose overrides ---
# JWT_SECRET=...
# VITE_API_URL=http://localhost:8080

# --- OpenRouter AI staff (org keys in app; these tune server-side tool calling) ---
# OPENROUTER_CHAT_TOOLS_ENABLED=true
# OPENROUTER_CHAT_SKIP_PREREAD=true
# OPENROUTER_WEB_SEARCH_TOOL=true
# OPENROUTER_DATETIME_TOOL=true
# OPENROUTER_WEB_SEARCH_MAX_RESULTS=5
# OPENROUTER_WEB_SEARCH_MAX_TOTAL_RESULTS=15
# OPENROUTER_WEB_SEARCH_ENGINE=auto
# OPENROUTER_CHAT_MAX_TOOL_ITERATIONS=12
# OPENROUTER_CHAT_TOOL_STEP_TIMEOUT_SEC=90
# Optional JSON object for OpenRouter "reasoning" (reasoning-capable models). Examples:
#   {"effort":"high"}   {"max_tokens":4096}   {"enabled":true}   {"effort":"medium","exclude":true}
# See https://openrouter.ai/docs/guides/best-practices/reasoning-tokens
# OPENROUTER_CHAT_REASONING_JSON=
# When using reasoning, set max_tokens high enough for thinking + answer (e.g. Anthropic needs max_tokens > reasoning budget).
# OPENROUTER_CHAT_MAX_TOKENS=16000
# Optional JSON array of OpenRouter request plugins, e.g. [{"id":"response-healing"}]
# OPENROUTER_PLUGINS_JSON=
