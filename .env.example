# Hyperspeed — developer reference only (comments are OK here).
#
# Docker Compose (local): copy this file to `.env` in the repo root (gitignored).
#   cp .env.example .env
#
# Hosting panels (Hostinger, etc.): do NOT paste this file. Use `deploy.env` instead.
#   It has only KEY=value lines (no #), so panels do not treat comments as variable names.

# --- Copy `deploy.env` for Docker stack keys; below is extra local-dev-only ---

# Local dev without Docker (API on host; Postgres/Redis via compose or local)
# DATABASE_URL=postgres://hyperspeed:hyperspeed@localhost:5432/hyperspeed?sslmode=disable
# REDIS_URL=redis://localhost:6379/0
# HTTP_ADDR=:8080

# Local Vite (apps/web) against native API
# VITE_API_URL=http://localhost:8080
# CORS_ORIGIN=http://localhost:5173

# Optional: override bundled MinIO in compose (advanced)
# FILES_S3_ENDPOINT=
# FILES_S3_REGION=
# FILES_S3_BUCKET=
# FILES_S3_ACCESS_KEY=
# FILES_S3_SECRET_KEY=
# FILES_S3_FORCE_PATH_STYLE=true

# Optional: OpenRouter AI tuning (see apps/api)
# OPENROUTER_CHAT_TOOLS_ENABLED=true
# OPENROUTER_WEB_SEARCH_TOOL=true
# OPENROUTER_CHAT_MAX_TOOL_ITERATIONS=12
# OPENROUTER_CHAT_REASONING_JSON=
# OPENROUTER_CHAT_MAX_TOKENS=16000
# OPENROUTER_PLUGINS_JSON=
