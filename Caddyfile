{
	# Used when you add a TLS site block later; optional for HTTP-only.
	email {$CADDY_EMAIL}
}

# HTTP on :80 inside the container (any Host header — localhost, server IP, or domain).
# Default compose maps host port 18080 → 80 so first deploy works without binding host 80/443.
# For HTTPS with automatic certs at the app, replace this block with your hostname — see README_SELF_HOST.md.
http:// {
	encode gzip

	handle /api/* {
		reverse_proxy api:8080
	}

	handle /health {
		reverse_proxy api:8080
	}

	handle {
		reverse_proxy web:80
	}
}
