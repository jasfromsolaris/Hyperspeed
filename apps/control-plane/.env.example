# Copy to .env or set on your host (Fly/Railway/VM). Never commit real values.
# Repo docker-compose.provisioning.yml loads this file (apps/control-plane/.env) into the control-plane and API containers.

# Cloudflare — zone-scoped DNS edit token from dash.cloudflare.com → API Tokens (control plane DNS)
CLOUDFLARE_API_TOKEN=

# Optional: separate token for Workers / KV (provisioning gateway Wrangler). Required if CLOUDFLARE_API_TOKEN is DNS-only.
# CLOUDFLARE_WORKERS_API_TOKEN=

# Cloudflare — zone Overview → Zone ID for your apex (e.g. hyperspeedapp.com)
CLOUDFLARE_ZONE_ID=

# Long random secret; the provisioning gateway Worker sends this in Authorization (not the customer API)
CONTROL_PLANE_BEARER_TOKEN=

# Worker admin endpoint for issuing one-time bootstrap tokens automatically (no customer secret paste).
# Keep this secret server-to-server only.
# WORKER_ADMIN_URL=https://provision-gw.hyperspeedapp.com
# WORKER_ADMIN_TOKEN=
# PROVISIONING_BASE_URL=https://provision-gw.hyperspeedapp.com

# Public HTTPS base URL of *this* control plane, as reachable from Cloudflare (no trailing slash).
# Leave unset until your host (e.g. Render) finishes deploy and shows a URL like https://xyz.onrender.com — then paste it here and run `npm run cf:secrets` from workers/provisioning-gateway.
# WORKER_CONTROL_PLANE_URL=https://your-service.onrender.com

# Optional
# BASE_DOMAIN=hyperspeedapp.com
# HTTP_ADDR=:8787
# AUDIT_DB_PATH=./data/control-plane.sqlite
# CLOUDFLARE_PROXIED=false
